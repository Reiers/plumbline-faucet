# ─── Required ─────────────────────────────────────────────────────
# Dispenser private key. Must hold tFIL + USDFC on Calibration.
FAUCET_PK=0xchange_me

# Cloudflare Turnstile (captcha). Strongly recommended for any public
# deployment; without these the captcha is bypassed and the server logs
# a warning on every boot.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ─── Network / dispenser ──────────────────────────────────────────
RPC_URL=https://api.calibration.node.glif.io/rpc/v1
USDFC_ADDRESS=0xb3042734b608a1B16e9e86B374A3f3e389B4cDf0

# ─── Drip amounts ─────────────────────────────────────────────────
FIL_DRIP=5
USDFC_DRIP=100

# ─── Rate limits ──────────────────────────────────────────────────
IP_RATE_LIMIT_SEC=86400
ADDRESS_RATE_LIMIT_SEC=86400
# How many drips of a given asset are allowed inside the window above.
# Tuned to 2 so a user can retry once if the first attempt feels stuck.
MAX_DRIPS_PER_IP=2
MAX_DRIPS_PER_ADDRESS=2
GLOBAL_RPS=5

# ─── Reserves (faucet refuses drips below dispenser reserve+drip) ─
MIN_RESERVE_FIL=20
MIN_RESERVE_USDFC=500

# ─── Bind ─────────────────────────────────────────────────────────
PORT=8003
HOST=0.0.0.0
TRUSTED_PROXY=true
RATE_LIMIT_DB=./rate-limits.sqlite

# ─── Branding (rendered in the UI) ────────────────────────────────
# BRAND_URL: optional. If set, the landing-page footer renders
# "Operated by <BRAND_NAME>" linking to BRAND_URL. Leave blank to
# show only the source link.
BRAND_NAME=Calibration Faucet
# Example for the canonical deployment:
#   BRAND_URL=https://faucet.reiers.io
BRAND_URL=
